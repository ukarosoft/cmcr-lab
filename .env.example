# ==========================================================
# Django core
# ==========================================================
SECRET_KEY=changeme-generate-with-python-secrets
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.prod
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://localhost,https://127.0.0.1

# ==========================================================
# Base de datos
# ==========================================================
DATABASE_URL=postgresql://user:password@localhost:5432/ukaro_db

# Para docker-compose
DB_NAME=ukaro_db
DB_USER=ukaro
DB_PASSWORD=changeme

# ==========================================================
# Email (SMTP)
# ==========================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ukarasoft.com

# ==========================================================
# Observabilidad (Sentry — opcional en prod)
# ==========================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==========================================================
# IA (opcional — rag-pipeline skill)
# ==========================================================
OPENROUTER_API_KEY=
GEMINI_API_KEY=
